# Copie este arquivo para .env e preencha sua chave real.
# Nunca envie o arquivo .env para o GitHub.

OPENAI_API_KEY=replace-with-your-openai-api-key

# Modelo usado futuramente na extracao dos dados de imagens/PDFs.
OPENAI_MODEL=gpt-4.1-mini

DJANGO_SECRET_KEY=django-insecure-local-dev-key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
